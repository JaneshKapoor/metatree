# MetaTree environment variables
# Copy this file to `.env` and fill in the values below.

# Base URL of your OpenMetadata instance (must include `/api`).
# Where to find: this is the base URL of your OpenMetadata instance.
# For the public sandbox use the value below.
OPENMETADATA_HOST=https://sandbox.open-metadata.org/api

# JWT token for authenticating to the OpenMetadata REST API.
# Where to find: Go to your OpenMetadata instance -> Settings (gear icon, bottom left)
# -> Bots -> ingestion-bot -> click the bot -> copy the token shown.
# For the sandbox: https://sandbox.open-metadata.org -> Settings -> Bots -> ingestion-bot -> JWT Token.
OPENMETADATA_JWT_TOKEN=

# GitHub token used by the GitHub Action to post PR comments.
# Where to find: GitHub -> Settings -> Developer Settings -> Personal Access Tokens
# -> Tokens (classic) -> Generate new token with `repo` scope.
# Only needed for the GitHub Action PR comment feature; in CI you can pass
# ${{ github.token }} directly to the action's `github-token` input instead.
GITHUB_TOKEN=
